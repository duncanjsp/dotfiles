{{- if eq .chezmoi.hostname "test-track" }}
{{- $workOrgs := list "agilebits-inc" "agilebits-tst-EMU" }}
{{- $workUsers := list "ben-kirby_1pw" "duncan-stevenson_1pw" "riyad-khan_1pw" }}
[url "ssh://git@ssh.gitlab.1password.io:2227"]
	insteadOf = https://gitlab.1password.io

[url "git@github.com:"]
	insteadOf = https://github.com/
{{ range $workOrgs }}
[url "git@github.com-work:{{ . }}/"]
	insteadOf = git@github.com:{{ . }}/
	insteadOf = https://github.com/{{ . }}/
{{ end }}

{{- range $workUsers }}
[url "git@github.com-work:{{ . }}/"]
	insteadOf = git@github.com:{{ . }}/
{{ end }}
[url "git@github.com-personal:"]
	insteadOf = git@github.com:

{{- end }}
[gpg]
	format = ssh
[alias]
	co = checkout
	getremote = !git fetch && git reset --hard @{u}
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
[user]{{ if eq .chezmoi.hostname "test-track" }}
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAEDbXQOIRzbFI6Q3q0RHWVHloBrEcNagqPfk4fhbtsY{{ else }}
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIL2ypgsJT6cu614LIGHPhNEK+l084Txm7SjkMZVPlX0z{{ end }}
	name = Duncan Stevenson-Price
	email = {{ .email }}
[core]
	eol = lf
	autocrlf = false
[fsck]
	zeroPaddedFilemode = ignore
[fetch "fsck"]
	zeroPaddedFilemode = ignore
[receive "fsck"]
	zeroPaddedFilemode = ignore
